{
  "name": "eximpe-bot",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:webhook": "pnpm --filter webhook dev",
    "build": "pnpm --filter @eximpe-bot/shared build && pnpm --filter webhook build",
    "db:migrate": "pnpm --filter @eximpe-bot/db migrate"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
